{
  "name": "vscode-autopr",
  "displayName": "AutoPR",
  "description": "Generate commit messages using Claude AI",
  "version": "0.2.0",
  "repository": "https://github.com/morcen/vscode-autopr",
  "publisher": "morcen",
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autopr.generateCommitMessage",
        "title": "AutoPR: Generate Commit Message",
        "icon": "$(hubot)",
        "shortTitle": "Generate Commit"
      },
      {
        "command": "autopr.createPullRequest",
        "title": "AutoPR: Create Pull Request",
        "icon": "$(git-pull-request)",
        "shortTitle": "Create PR"
      }
    ],
    "menus": {
      "scm/inputBox": [
        {
          "command": "autopr.generateCommitMessage"
        }
      ],
      "scm/title": [
        {
          "command": "autopr.generateCommitMessage",
          "group": "navigation"
        },
        {
          "command": "autopr.createPullRequest",
          "group": "navigation",
          "when": "autopr.isNotMainBranch"
        }
      ]
    },
    "configuration": {
      "title": "AutoPR",
      "properties": {
        "autopr.model": {
          "type": "string",
          "default": "claude-opus-4-6",
          "description": "Claude model to use for generating commit messages"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "compile": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.94.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0"
  }
}
